tidy_planning <- function(df, var = "inf") {
df %>%
select(-Total) %>%
pivot_longer(!Semaine, names_to = "day", values_to = "start") %>%
mutate(infirmier := {{var}}) %>%
mutate(Date = seq(as.Date("2025-01-01"), by = "day",
length.out = nrow(.))) %>%
filter(!is.na(start) & start != "RH") %>%  # filter might not be necessary
mutate(start = paste0("0",start),
start = stringr::str_replace(start, "h", "-"),
start = paste0(Date,"-",start),
start = as.POSIXct(start, format = '%Y-%m-%d-%H-%M'),
end = start + lubridate::hm("12:00"),
.before = infirmier)
}
tidy_planning(df, "inf1")
raw <- tibble::tribble(
~Semaine, ~Lundi, ~Mardi, ~Mercredi, ~Jeudi, ~Vendredi, ~Samedi, ~Dimanche,  ~Total,
"Semaine 1", "9h00",     NA,      "RH",   "RH",    "7h00",  "7h00",    "7h00", "48h00",
"Semaine 2",     NA,     NA,        NA, "9h00",    "9h00",    "RH",      "RH", "24h00",
"Semaine 3",     NA, "9h00",    "9h00",   "RH",      "RH",  "7h30",    "7h30", "48h00",
"Semaine 4",     NA,     NA,    "7h00", "7h00",        NA,    "RH",      "RH", "24h00",
"Semaine 5",     NA, "7h30",    "7h30", "7h30",        NA,    "RH",      "RH", "36h00",
"Semaine 6", "7h30",     NA,        NA, "9h00",    "9h00",    "RH",      "RH", "36h00",
"Semaine 7", "9h00", "9h00",        NA,   "RH",      "RH",  "7h30",    "7h30", "48h00",
"Semaine 8", "7h30",     NA,        NA,     NA,    "7h30",    "RH",      "RH", "24h00",
"Semaine 9", "7h00", "7h00",        NA,   "RH",      "RH",  "9h00",    "9h00", "48h00",
"Semaine 10",     NA,     NA,    "9h00", "9h00",        NA,    "RH",      "RH", "24h00"
)
tidy_planning <- function(df, var = "inf") {
df %>%
select(-Total) %>%
pivot_longer(!Semaine, names_to = "day", values_to = "start") %>%
mutate(infirmier := {{var}}) %>%
mutate(Date = seq(as.Date("2025-01-01"), by = "day",
length.out = nrow(.))) %>%
filter(!is.na(start) & start != "RH") %>%  # filter might not be necessary
mutate(start = paste0("0",start),
start = stringr::str_replace(start, "h", "-"),
start = paste0(Date,"-",start),
start = as.POSIXct(start, format = '%Y-%m-%d-%H-%M'),
end = start + lubridate::hm("12:00"),
.before = infirmier)
}
