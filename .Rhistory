tidy_planning <- function(df, var = "inf") {
df %>%
select(-Total) %>%
pivot_longer(!Semaine, names_to = "day", values_to = "start") %>%
mutate(infirmier := {{var}}) %>%
mutate(Date = seq(as.Date("2025-01-01"), by = "day",
length.out = nrow(.))) %>%
filter(!is.na(start) & start != "RH") %>%  # filter might not be necessary
mutate(start = paste0("0",start),
start = stringr::str_replace(start, "h", "-"),
start = paste0(Date,"-",start),
start = as.POSIXct(start, format = '%Y-%m-%d-%H-%M'),
end = start + lubridate::hm("12:00"),
.before = infirmier)
}
